{
  "name": "a2ui-composer-shell",
  "version": "0.1.0",
  "private": true,
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "type": "module",
  "scripts": {
    "start": "yarn workspace ng-basic-catalog build && ng serve",
    "build": "yarn lint && ng build",
    "test": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e-headless": "E2E_HEADLESS=true playwright test",
    "prettier": "prettier --ignore-path ../.prettierignore --write . | grep -v '(unchanged)'",
    "prettier:check": "prettier --ignore-path ../.prettierignore --check .",
    "clean": "rm -rf dist .angular node_modules/.vite",
    "lint": "eslint ."
  },
  "dependencies": {
    "@angular/animations": "22.0.6",
    "@angular/cdk": "22.0.4",
    "@angular/common": "22.0.6",
    "@angular/compiler": "22.0.6",
    "@angular/core": "22.0.6",
    "@angular/forms": "22.0.6",
    "@angular/material": "22.0.4",
    "@angular/platform-browser": "22.0.6",
    "@angular/router": "22.0.6",
    "@google/genai": "2.11.0",
    "@monaco-editor/loader": "1.7.0",
    "a2ui-bridge": "0.1.0",
    "dockview": "7.0.2",
    "monaco-editor": "^0.55.1",
    "rxjs": "7.8.2",
    "safevalues": "1.2.0",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "2.6.3",
    "@angular-devkit/build-angular": "22.0.7",
    "@angular/build": "22.0.7",
    "@angular/cli": "22.0.7",
    "@angular/compiler-cli": "22.0.6",
    "@angular/platform-browser-dynamic": "22.0.6",
    "@playwright/test": "1.61.1",
    "@types/jsdom": "28.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "angular-eslint": "22.1.0",
    "eslint": "10.7.0",
    "jsdom": "29.1.1",
    "ng-basic-catalog": "0.1.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.8"
  }
}
