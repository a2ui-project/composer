{
  "name": "react-basic-catalog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite --port 3458",
    "dev": "vite --port 3458",
    "build": "yarn lint && tsc && vite build",
    "preview": "vite preview",
