  "dependencies": {
    "@a2ui/react": "0.10.0",
    "@a2ui/web_core": "0.10.0",
    "a2ui-bridge": "0.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "angular-eslint": "22.0.0",
    "eslint": "10.5.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
