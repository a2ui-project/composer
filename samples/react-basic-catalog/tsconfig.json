{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "sourceMap": true,
    "jsx": "react-jsx",
    "noEmit": true
  },
  "include": ["src/**/*"]
}
