{
  "name": "lit-basic-catalog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite --port 3457",
    "dev": "vite --port 3457",
    "build": "yarn lint && tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "prettier": "prettier --ignore-path ../../.prettierignore --write . | grep -v '(unchanged)'",
    "prettier:check": "prettier --ignore-path ../../.prettierignore --check .",
    "clean": "rm -rf dist node_modules/.vite",
    "lint": "eslint ."
  },
  "dependencies": {
    "@a2ui/lit": "0.10.2",
    "@a2ui/markdown-it": "0.1.0",
    "@a2ui/web_core": "0.10.5",
    "@lit-labs/signals": "0.3.0",
    "@lit/context": "1.1.6",
    "a2ui-bridge": "0.1.0",
    "lit": "3.3.3",
    "markdown-it": "14.2.0"
  },
  "devDependencies": {
    "eslint": "10.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
